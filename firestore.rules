rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasProfile() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActive() {
      return hasProfile() && userProfile().data.isActive == true;
    }

    function role() {
      return userProfile().data.role;
    }

    function isAdmin() {
      return isActive() && role() == "Admin";
    }

    function isOperator() {
      return isActive() && role() == "Operator";
    }

    function operatorCreatesOwnLoad() {
      return isOperator()
        && request.resource.data.operatorId == request.auth.uid
        && request.resource.data.validationStatus == "NotValidated";
    }

    match /users/{uid} {
      allow read: if hasProfile() && (isAdmin() || uid == request.auth.uid);
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /loadRecords/{id} {
      allow get: if isAdmin()
        || (isOperator()
          && (!exists(/databases/$(database)/documents/loadRecords/$(id))
            || resource.data.operatorId == request.auth.uid));
      allow list: if isAdmin();
      allow create: if isAdmin() || operatorCreatesOwnLoad();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /drivers/{id} {
      allow read: if isActive();
      allow create, update: if isActive();
      allow delete: if isAdmin();
    }

    match /vehicles/{id} {
      allow read: if isActive();
      allow create, update: if isActive();
      allow delete: if isAdmin();
    }

    match /editLogs/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /validationLogs/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /syncLogs/{id} {
      allow read: if isAdmin();
      allow create: if isActive();
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}

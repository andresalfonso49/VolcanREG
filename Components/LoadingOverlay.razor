@if (Visible)
{
    <div class="loading-overlay">
        <div class="loading-panel">
            <div class="spinner"></div>
            <strong>@Text</strong>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public string Text { get; set; } = "Cargando...";
}
